};

const PlateTest = () => {
  const [inputs, setInputs] = useState({
    length: 400,
    width: 124,
    thickness: 2.82,
    mass: 59,
    freqTorsion: 60,
    freqFlexLength: 90,
    freqFlexWidth: 144
  });

  const [results, setResults] = useState(null);
  const [showGuide, setShowGuide] = useState(false);

  const calculate = () => {
    const L = inputs.length / 1000;
    const W = inputs.width / 1000;
    const h = inputs.thickness / 1000;
    const m = inputs.mass / 1000;
    const f_tors = inputs.freqTorsion;
    const f_flex_L = inputs.freqFlexLength;
    const f_flex_W = inputs.freqFlexWidth;

    // Constants
    const nuxy = 0.3;
    const nuyx = 0.03;

    // Calculated values
    const volume = L * W * h;
    const density = m / volume;

    // Rigidity calculations (McIntyre-Woodhouse method)
    const D2 = 0.0789 * f_flex_L * f_flex_L * density * L * L * L * L / (h * h);
    const D1 = 0.0789 * f_flex_W * f_flex_W * density * W * W * W * W / (h * h);
    const D3 = 0.4053 * f_tors * f_tors * density * L * L * W * W / (h * h);

    const E2 = D2 * 12 * (1 - nuxy * nuyx) * 0.000000001;
    const E1 = D1 * 12 * (1 - nuxy * nuyx) * 0.000000001;
    const G12 = D3 * 3 * 0.000000001;

    const specificRigidity1 = E1 / (density / 1000);
    const specificRigidity2 = E2 / (density / 1000);
    const ratioAnisotropy = E1 / E2;

    // Wave celerities
    const C2 = Math.sqrt((E2 * 1000000000 * (1 - nuxy)) / (density * (1 + nuxy) * (1 - 2 * nuxy)));
    const C1 = Math.sqrt((E1 * 1000000000 * (1 - nuxy)) / (density * (1 + nuxy) * (1 - 2 * nuxy)));
    const shearWaves = 0.58 * Math.sqrt(L * L + W * W) * f_tors;

    // Predicted frequencies using reference materials
    const sg = density / 1000;

    // Softwoods
    const EL_soft = 11.73164;
    const ER_soft = 0.844978;
    const GLR_soft = 0.802795;
    const D1_soft = (EL_soft * 1000000000 * h * h * h) / (12 * (1 - nuxy * nuyx));
    const D2_soft = (ER_soft * 1000000000 * h * h * h) / (12 * (1 - nuxy * nuyx));
    const D3_soft = (GLR_soft * 1000000000 * h * h * h) / 3;
    const freq_flex_L_soft = Math.sqrt((0.0789 * D1_soft) / (density * W * W * W * W / (h * h)));
    const freq_flex_W_soft = Math.sqrt((0.0789 * D2_soft) / (density * L * L * L * L / (h * h)));
    const freq_tors_soft = Math.sqrt((0.4053 * D3_soft) / (density * L * L * W * W / (h * h)));

    // Hardwoods
    const EL_hard = 9.38528;
    const ER_hard = 1.029674;
    const GLR_hard = 0.564065;
    const D1_hard = (EL_hard * 1000000000 * h * h * h) / (12 * (1 - nuxy * nuyx));
    const D2_hard = (ER_hard * 1000000000 * h * h * h) / (12 * (1 - nuxy * nuyx));
    const D3_hard = (GLR_hard * 1000000000 * h * h * h) / 3;
    const freq_flex_L_hard = Math.sqrt((0.0789 * D1_hard) / (density * W * W * W * W / (h * h)));
    const freq_flex_W_hard = Math.sqrt((0.0789 * D2_hard) / (density * L * L * L * L / (h * h)));
    const freq_tors_hard = Math.sqrt((0.4053 * D3_hard) / (density * L * L * W * W / (h * h)));

    setResults({
      density,
      E1,
      E2,
      G12,
      specificRigidity1,
      specificRigidity2,
      ratioAnisotropy,
      C1,
      C2,
      predictions: {
        softwoods: {
          freqFlexLength: freq_flex_L_soft,
          freqFlexWidth: freq_flex_W_soft,
          freqTorsion: freq_tors_soft,
          diffFlexLength: ((f_flex_L - freq_flex_L_soft) / freq_flex_L_soft * 100),
          diffFlexWidth: ((f_flex_W - freq_flex_W_soft) / freq_flex_W_soft * 100),
          diffTorsion: ((f_tors - freq_tors_soft) / freq_tors_soft * 100)
        },
        hardwoods: {
          freqFlexLength: freq_flex_L_hard,
          freqFlexWidth: freq_flex_W_hard,
          freqTorsion: freq_tors_hard,
          diffFlexLength: ((f_flex_L - freq_flex_L_hard) / freq_flex_L_hard * 100),
          diffFlexWidth: ((f_flex_W - freq_flex_W_hard) / freq_flex_W_hard * 100),
          diffTorsion: ((f_tors - freq_tors_hard) / freq_tors_hard * 100)
        }
      }
    });
  };

  return (
    <div className="space-y-6">
      {/* Measurement Guide */}
      <div className="measurement-guide">
        <button 
          className="guide-toggle"
          onClick={() => setShowGuide(!showGuide)}
        >
          <span>📐 How to Measure These Frequencies</span>
          <span className="toggle-icon">{showGuide ? '▼' : '▶'}</span>
        </button>
        
        {showGuide && (
          <div className="guide-content">
            <div className="guide-section">
              <h4>Setup</h4>
              <p>For each mode, you'll support the plate differently. Use soft foam or strings at the nodal lines. The plate must be completely free to vibrate.</p>
            </div>

            <div className="guide-diagrams">
              {/* Torsion Mode */}
              <div className="diagram-card">
                <h5>Torsion Mode (Twisting)</h5>
                <svg viewBox="0 0 300 160" className="mode-diagram">
                  {/* Plate */}
                  <rect x="60" y="50" width="180" height="70" fill="#d4c4a8" stroke="#8b7355" strokeWidth="2" rx="2"/>
                  {/* Support center */}
                  <circle cx="150" cy="85" r="6" fill="#6b5a45"/>
                  <text x="150" y="105" fontSize="10" textAnchor="middle" fill="#5a4a35">Support center</text>
                  {/* Tap corner */}
                  <path d="M 235 35 L 225 50" stroke="#c44" strokeWidth="3" markerEnd="url(#arrowplate1)"/>
                  <text x="245" y="30" fontSize="12" fontWeight="bold" fill="#c44">TAP</text>
                  <text x="245" y="42" fontSize="9" fill="#c44">corner</text>
                  {/* Diagonal twist lines */}
                  <path d="M 65 55 L 235 115" stroke="#4a90e2" strokeWidth="1.5" strokeDasharray="3,3" opacity="0.5"/>
                  <path d="M 235 55 L 65 115" stroke="#4a90e2" strokeWidth="1.5" strokeDasharray="3,3" opacity="0.5"/>
                  <defs>
                    <marker id="arrowplate1" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L0,6 L9,3 z" fill="#c44" />
                    </marker>
                  </defs>
                </svg>
                <div className="diagram-notes">
                  <p><strong>What to do:</strong> Tap at corner, plate twists diagonally</p>
                  <p><strong>Expected range:</strong> 50-150 Hz (usually the lowest mode)</p>
                </div>
              </div>

              {/* Flexure Length */}
              <div className="diagram-card">
                <h5>Flexure Along Length</h5>
                <svg viewBox="0 0 300 160" className="mode-diagram">
                  {/* Plate */}
