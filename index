    const area_L = h1 * l + (h1 * (h2 - h1) / 2);
    const area_R = L * h_avg;
    const volume = area_L * L;
    const density = m / volume;
    const SMA_L = (l * h_avg * h_avg * h_avg) / 12;
    const SMA_R = (L * h_avg * h_avg * h_avg * h_avg) / 12;

    // Pulsation and wavenumber
