                  <span className={`freq-diff ${Math.abs(results.predictions.softwoods.diffTorsion) < 5 ? 'good' : Math.abs(results.predictions.softwoods.diffTorsion) < 15 ? 'ok' : 'different'}`}>
                    {results.predictions.softwoods.diffTorsion > 0 ? '+' : ''}{results.predictions.softwoods.diffTorsion.toFixed(1)}%
                  </span>
