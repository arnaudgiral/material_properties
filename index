const BeamTest = () => {
  const [inputs, setInputs] = useState({
    length: 248,
    width: 56,
    thickness: 6,
    mass: 33.3,
    freqFlexural: 519,
    freqTorsion: 300
  });

  const [results, setResults] = useState(null);
  const [showGuide, setShowGuide] = useState(false);

  const calculate = () => {
    const L = inputs.length / 1000; // Convert to meters
    const b = inputs.width / 1000;
    const h = inputs.thickness / 1000;
    const m = inputs.mass / 1000; // Convert to kg
    const f_flex = inputs.freqFlexural;
    const f_tors = inputs.freqTorsion;

    // Constants
    const nuxy = 0.3;
    const nuyx = 0.03;
    const knL = 4.73; // Free beam constant

    // Calculated values
    const volume = L * b * h;
    const density = m / volume;
    const I = (b * h * h * h) / 12;
    const J = (b * h * h * h) * (1/3 - 0.21 * (h/b) * (1 - (h*h*h*h)/(12*b*b*b*b)));

    // Rigidity calculations
    const E1 = (f_flex * f_flex * nuxy * b * h * L * L * L * L * 4 * Math.PI * Math.PI) / (knL * 500.4) / 1000000000;
    const specificRigidity = E1 / (density / 1000);
    const G12 = ((4 * L * L * f_tors * f_tors * density * J) / I) / 1000000000;

    // Wave celerities
    const celerityTC = Math.sqrt((E1 * 1000000000) / (density * (1 - 0.3 * 0.3)));
    const celerityTorsion = Math.sqrt((G12 * 1000000000) / density);
    const celerityFlexural = (Math.pow((E1 * 1000000000 * I) / (density * (h * b)), 0.25)) * Math.sqrt(2 * Math.PI * f_flex);
    const wavelengthFlexural = celerityFlexural / f_flex;

    // Predicted frequencies using Guitard model
    const sg = density / 1000;
    
    // Softwoods predictions
    const EL_soft = 13 + 45 * (sg - 0.45);
    const GLR_soft = 14.2 + 21.1 * (sg - 0.65);
    const specificRigidity_soft = EL_soft / sg;
    const freq_flex_soft = Math.sqrt((specificRigidity_soft * 1000 * I * Math.PI * Math.PI * knL * knL) / (L * L * L * L));
    const freq_tors_soft = Math.sqrt((GLR_soft * 1000 * I) / (density * L * L * J));

    // Hardwoods predictions
    const EL_hard = 8.5 + 21.1 * (sg - 0.65);
    const GLR_hard = 0.52 * EL_hard;
    const specificRigidity_hard = EL_hard / sg;
    const freq_flex_hard = Math.sqrt((specificRigidity_hard * 1000 * I * Math.PI * Math.PI * knL * knL) / (L * L * L * L));
    const freq_tors_hard = Math.sqrt((GLR_hard * 1000 * I) / (density * L * L * J));

    setResults({
      density,
      E1,
      specificRigidity,
      G12,
      celerityTC,
      celerityTorsion,
      predictions: {
        softwoods: {
          freqFlexural: freq_flex_soft,
          freqTorsion: freq_tors_soft,
          diffFlexural: ((f_flex - freq_flex_soft) / freq_flex_soft * 100),
          diffTorsion: ((f_tors - freq_tors_soft) / freq_tors_soft * 100)
        },
        hardwoods: {
          freqFlexural: freq_flex_hard,
          freqTorsion: freq_tors_hard,
          diffFlexural: ((f_flex - freq_flex_hard) / freq_flex_hard * 100),
          diffTorsion: ((f_tors - freq_tors_hard) / freq_tors_hard * 100)
        }
      }
    });
  };

  return (
    <div className="space-y-6">
      {/* Measurement Guide */}
      <div className="measurement-guide">
        <button 
          className="guide-toggle"
          onClick={() => setShowGuide(!showGuide)}
        >
          <span>📐 How to Measure These Frequencies</span>
          <span className="toggle-icon">{showGuide ? '▼' : '▶'}</span>
        </button>
        
        {showGuide && (
          <div className="guide-content">
            <div className="guide-section">
              <h4>Setup</h4>
              <p>Support the beam at the <strong>nodal points</strong> (22% from each end) using soft foam or strings. The beam must be free to vibrate.</p>
            </div>

            <div className="guide-diagrams">
              {/* Flexural Mode Diagram */}
              <div className="diagram-card">
                <h5>Flexural Mode</h5>
                <svg viewBox="0 0 300 120" className="mode-diagram">
                  {/* Beam */}
                  <rect x="30" y="50" width="240" height="20" fill="#d4c4a8" stroke="#8b7355" strokeWidth="2" rx="2"/>
                  {/* Support points */}
                  <circle cx="83" cy="80" r="6" fill="#6b5a45"/>
                  <circle cx="217" cy="80" r="6" fill="#6b5a45"/>
                  <text x="83" y="100" fontSize="10" textAnchor="middle" fill="#5a4a35">Support</text>
                  <text x="217" y="100" fontSize="10" textAnchor="middle" fill="#5a4a35">Support</text>
                  {/* Tap point */}
                  <path d="M 150 20 L 150 45" stroke="#c44" strokeWidth="3" markerEnd="url(#arrowred)"/>
                  <text x="150" y="15" fontSize="12" fontWeight="bold" textAnchor="middle" fill="#c44">TAP HERE</text>
                  {/* Vibration curve */}
                  <path d="M 30 60 Q 90 30, 150 60 T 270 60" fill="none" stroke="#4a90e2" strokeWidth="2" strokeDasharray="4,4" opacity="0.6"/>
                  <defs>
                    <marker id="arrowred" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
                      <path d="M0,0 L0,6 L9,3 z" fill="#c44" />
                    </marker>
                  </defs>
                </svg>
                <div className="diagram-notes">
                  <p><strong>What to do:</strong> Tap at center, support at 22% from ends</p>
                  <p><strong>Expected range:</strong> 300-700 Hz (softwood), 250-600 Hz (hardwood)</p>
                  <p><strong>In Audacity:</strong> Look for the <em>lowest strong peak</em></p>
                </div>
              </div>

              {/* Torsion Mode Diagram */}
              <div className="diagram-card">
                <h5>Torsion Mode</h5>
                <svg viewBox="0 0 300 120" className="mode-diagram">
                  {/* Beam */}
                  <rect x="30" y="50" width="240" height="20" fill="#d4c4a8" stroke="#8b7355" strokeWidth="2" rx="2"/>
                  {/* Support point (center) */}
                  <circle cx="150" cy="80" r="6" fill="#6b5a45"/>
                  <text x="150" y="100" fontSize="10" textAnchor="middle" fill="#5a4a35">Support center</text>
                  {/* Tap point */}
                  <path d="M 260 30 L 245 45" stroke="#c44" strokeWidth="3" markerEnd="url(#arrowred2)"/>
                  <text x="265" y="25" fontSize="12" fontWeight="bold" textAnchor="middle" fill="#c44">TAP</text>
                  <text x="265" y="38" fontSize="10" textAnchor="middle" fill="#c44">corner</text>
                  {/* Twist indication */}
                  <path d="M 30 45 L 30 75" stroke="#4a90e2" strokeWidth="2" opacity="0.6"/>
                  <path d="M 270 55 L 270 65" stroke="#4a90e2" strokeWidth="2" opacity="0.6"/>
                  <text x="20" y="60" fontSize="10" fill="#4a90e2">↻</text>
                  <defs>
                    <marker id="arrowred2" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
                      <path d="M0,0 L0,6 L9,3 z" fill="#c44" />
                    </marker>
                  </defs>
                </svg>
                <div className="diagram-notes">
                  <p><strong>What to do:</strong> Tap at corner/edge, beam should twist</p>
                  <p><strong>Expected range:</strong> 200-500 Hz (varies with shear modulus)</p>
                  <p><strong>In Audacity:</strong> Look for a <em>higher peak</em> than flexural</p>
                </div>
              </div>
            </div>

            <div className="guide-tips">
              <p><strong>💡 Tips:</strong></p>
              <ul>
                <li>Use a light tap with a pencil or small stick - don't hit too hard</li>
                <li>Record 2-3 seconds in Audacity, then Analyze → Plot Spectrum</li>
                <li>Look for clear, distinct peaks - ignore small bumps</li>
                <li>If you don't see a peak, try tapping at different locations</li>
              </ul>
            </div>
          </div>
        )}
      </div>

      {/* Inputs */}
      <div className="input-section">
        <h3 className="section-title">Sample Dimensions</h3>
        <div className="input-grid">
          <div className="input-group">
            <label>Length (mm)</label>
            <input
              type="number"
              value={inputs.length}
              onChange={(e) => setInputs({...inputs, length: parseFloat(e.target.value)})}
            />
          </div>
          <div className="input-group">
            <label>Width (mm)</label>
            <input
              type="number"
              value={inputs.width}
              onChange={(e) => setInputs({...inputs, width: parseFloat(e.target.value)})}
            />
          </div>
          <div className="input-group">
            <label>Thickness (mm)</label>
            <input
              type="number"
              value={inputs.thickness}
              onChange={(e) => setInputs({...inputs, thickness: parseFloat(e.target.value)})}
            />
          </div>
          <div className="input-group">
            <label>Mass (g)</label>
            <input
              type="number"
              value={inputs.mass}
              onChange={(e) => setInputs({...inputs, mass: parseFloat(e.target.value)})}
            />
          </div>
        </div>
      </div>

      <div className="input-section">
        <h3 className="section-title">Measured Frequencies</h3>
        <div className="input-grid">
          <div className="input-group">
            <label>Flexural Mode (Hz)</label>
            <input
              type="number"
              value={inputs.freqFlexural}
              onChange={(e) => setInputs({...inputs, freqFlexural: parseFloat(e.target.value)})}
            />
            <span className="hint">Tap along length, free-free beam</span>
          </div>
          <div className="input-group">
            <label>Torsion Mode (Hz)</label>
            <input
              type="number"
              value={inputs.freqTorsion}
              onChange={(e) => setInputs({...inputs, freqTorsion: parseFloat(e.target.value)})}
            />
            <span className="hint">Twist mode, free-free beam</span>
          </div>
        </div>
      </div>

      <button className="calculate-btn" onClick={calculate}>
        Calculate Properties
      </button>

      {/* Results */}
      {results && (
        <div className="results-section">
          <h3 className="section-title">Material Properties</h3>
          
          <div className="property-cards">
            <div className="property-card highlight">
              <div className="property-label">Specific Rigidity</div>
              <div className="property-value">{results.specificRigidity.toFixed(1)}</div>
