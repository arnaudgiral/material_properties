    EL: 10.733,
    ER: 0.723,
    ET: 0.539,
    GLR: 0.774,
    GRT: 0.039,
    GTL: 0.743
  },
  hardwoods: {
    specificGravity: 0.4,
    EL: 8.917,
    ER: 0.933,
    ET: 0.421,
    GLR: 0.519,
    GRT: 0.166,
    GTL: 0.649
